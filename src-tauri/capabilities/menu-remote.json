{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "menu-remote",
  "description": "Capability for menu window loaded from remote URL",
  "remote": {
    "urls": ["https://microsapptest.yadea.com.cn/*"],
    "allow": [
      "core:event:allow-emit",
      "core:event:allow-listen",
      "core:window:allow-show",
      "core:window:allow-hide"
    ]
  },
  "windows": ["menu"],
  "permissions": [
    "core:event:allow-emit",
    "core:event:allow-listen",
    "core:window:allow-show",
    "core:window:allow-hide"
  ]
}
