{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIDI Desktop",
  "version": "1.0.0",
  "identifier": "com.aidi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node build.js",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "url": "index.html",
        "width": 148,
        "height": 84,
        "decorations": false,
        "hiddenTitle": true,
        "transparent": true,
        "backgroundColor": "#00000000",
        "shadow": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": false,
        "visible": false,
        "x": 100,
        "y": 100,
        "acceptFirstMouse": true,
        "devtools": true
      },
      {
        "label": "optimizer",
        "title": "系统优化",
        "url": "optimizer.html",
        "width": 420,
        "height": 550,
        "decorations": true,
        "transparent": true,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "resizable": false,
        "center": true,
        "visible": false,
        "devtools": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["scripts/*", "icons/tray-icon.png"],
    "macOS": {
      "infoPlist": "Info.plist"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "schemes": ["aidi"]
    }
  }
}
