{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIDI Desktop",
  "version": "1.0.0",
  "identifier": "com.aidi.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AIDI",
        "width": 120,
        "height": 120,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": false,
        "visible": false,
        "x": 100,
        "y": 100,
        "acceptFirstMouse": true
      },
      {
        "label": "menu",
        "title": "Menu",
        "url": "menu.html",
        "width": 436,
        "height": 116,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "center": false,
        "visible": false
      },
      {
        "label": "optimizer",
        "title": "Optimizer",
        "url": "optimizer.html",
        "width": 420,
        "height": 550,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "resizable": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["scripts/*", "icons/tray-icon.png"]
  }
}
